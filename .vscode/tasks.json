{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run app",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/ReelsVideoEditor.App/ReelsVideoEditor.App.csproj"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "watch app",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/src/ReelsVideoEditor.App/ReelsVideoEditor.App.csproj"
      ],
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
