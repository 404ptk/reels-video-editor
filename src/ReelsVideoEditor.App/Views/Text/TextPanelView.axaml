<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Text"
             xmlns:models="using:ReelsVideoEditor.App.Models"
             x:Class="ReelsVideoEditor.App.Views.Text.TextPanelView"
             x:DataType="vm:TextViewModel">

    <StackPanel Spacing="12">
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource Accent}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Left" />
        <TextBlock Text="{Binding Description}"
                   Foreground="{DynamicResource AccentMuted}"
                   FontSize="13"
                   HorizontalAlignment="Left" />

        <ItemsControl ItemsSource="{Binding Presets}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:TextPresetDefinition">
                    <Border Width="154"
                            Height="108"
                            Margin="0,0,10,10"
                            Padding="10"
                            CornerRadius="10"
                            Background="#AA222222"
                            BorderBrush="{DynamicResource AccentSubtle}"
                            BorderThickness="1"
                            Cursor="Hand"
                            PointerPressed="PresetTile_OnPointerPressed">
                        <Grid RowDefinitions="Auto,*,Auto"
                              RowSpacing="4">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1"
                                       Text="{Binding DisplayText}"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       Foreground="{Binding ColorBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <Border Grid.Row="2"
                                    Height="8"
                                    CornerRadius="4"
                                    Background="{Binding ColorBrush}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>

</UserControl>
