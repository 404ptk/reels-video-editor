<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Text"
             xmlns:models="using:ReelsVideoEditor.App.Models"
             xmlns:commonViews="using:ReelsVideoEditor.App.Views.Common"
             x:Class="ReelsVideoEditor.App.Views.Text.TextPanelView"
             x:DataType="vm:TextViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.accentInput">
            <Setter Property="Background" Value="#111318" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="TextBox.accentInput:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="TextBox.accentInput:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="ComboBox.accentInput">
            <Setter Property="Background" Value="#111318" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="ComboBox.accentInput:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="Background" Value="#141921" />
        </Style>

        <Style Selector="ComboBox.accentInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="Background" Value="#141921" />
        </Style>

        <Style Selector="ComboBox.accentInput ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="Background" Value="#111318" />
        </Style>

        <Style Selector="ComboBox.accentInput ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
        </Style>

        <Style Selector="ComboBox.accentInput ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
        </Style>

        <Style Selector="ComboBox.accentInput ComboBoxItem:selected">
            <Setter Property="Foreground" Value="#0E1413" />
        </Style>

        <Style Selector="Button.presetIconBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Foreground" Value="{DynamicResource AccentMuted}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.presetIconBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="StackPanel.presetActions">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="Border.presetTile:pointerover StackPanel.presetActions">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsPresetVisible}">
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource Accent}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left" />
            <TextBlock Text="{Binding Description}"
                       Foreground="{DynamicResource AccentMuted}"
                       FontSize="13"
                       HorizontalAlignment="Left" />

            <ItemsControl ItemsSource="{Binding PresetTiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TextPresetDefinition">
                        <Border Width="154"
                                Height="108"
                                Margin="0,0,10,10"
                            Classes="presetTile"
                                Padding="10"
                                CornerRadius="10"
                                Background="#AA222222"
                                BorderBrush="{DynamicResource AccentSubtle}"
                                BorderThickness="1"
                                Cursor="Hand"
                                PointerEntered="PresetTile_OnPointerEntered"
                                PointerPressed="PresetTile_OnPointerPressed">
                            <Grid>
                                <Grid RowDefinitions="Auto,*,Auto"
                                      RowSpacing="4"
                                      IsVisible="{Binding IsRegularTile}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="4"
                                          MinHeight="22">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource AccentMuted}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="1"
                                                    Classes="presetActions"
                                                    Orientation="Horizontal"
                                                    Spacing="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Button Classes="presetIconBtn"
                                                    Command="{Binding $parent[UserControl].DataContext.EditPresetFromTileCommand}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="M4 20h4l10.5 -10.5a2.828 2.828 0 1 0 -4 -4l-10.5 10.5v4 M13.5 6.5l4 4"
                                                      Width="12"
                                                      Height="12"
                                                      Stretch="Uniform"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      Stroke="{Binding $parent[Button].Foreground}" />
                                            </Button>

                                            <Button Classes="presetIconBtn"
                                                    Command="{Binding $parent[UserControl].DataContext.DeletePresetFromTileCommand}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="M4 7l16 0 M10 11l0 6 M14 11l0 6 M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12 M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"
                                                      Width="12"
                                                      Height="12"
                                                      Stretch="Uniform"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      Stroke="{Binding $parent[Button].Foreground}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                     <Image Grid.Row="1"
                                         Source="{Binding PreviewImage}"
                                         Width="124"
                                         Height="40"
                                         Stretch="Uniform"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />

                                    <Border Grid.Row="2"
                                            Height="8"
                                            CornerRadius="4"
                                            Background="{Binding ColorBrush}" />
                                </Grid>

                                <StackPanel IsVisible="{Binding IsAddTile}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="8">
                                    <Path Data="M12 5l0 14 M5 12l14 0"
                                          Width="26"
                                          Height="26"
                                          Stretch="Uniform"
                                          Fill="Transparent"
                                          Stroke="{DynamicResource AccentMuted}"
                                          StrokeThickness="2"
                                          StrokeLineCap="Round"
                                          StrokeJoin="Round"
                                          HorizontalAlignment="Center" />
                                    <TextBlock Text="New preset"
                                               Foreground="{DynamicResource AccentMuted}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="12"
                        IsVisible="{Binding IsEditorVisible}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <commonViews:BackButton Command="{Binding BackToPresetsCommand}" />
                <StackPanel Grid.Column="1"
                            Spacing="2">
                    <TextBlock Text="{Binding EditorTitle}"
                               Foreground="{DynamicResource Accent}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding EditorDescription}"
                               Foreground="{DynamicResource AccentMuted}"
                               FontSize="12" />
                </StackPanel>
            </Grid>

            <Border Padding="12"
                    CornerRadius="10"
                    Background="#AA222222"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Text"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding SelectedClipText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Classes="accentInput"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 MinHeight="76" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Font"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <Grid x:Name="FontPickerRoot"
                              Width="280"
                              HorizontalAlignment="Left">
                            <TextBox x:Name="FontSearchTextBox"
                                     Classes="accentInput"
                                     Text="{Binding FontSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="FontSearchTextBox_OnKeyDown"
                                     GotFocus="FontSearchTextBox_OnGotFocus" />

                            <Popup x:Name="FontPickerPopup"
                                IsOpen="{Binding IsFontDropdownOpen, Mode=TwoWay}"
                                   Placement="BottomEdgeAlignedLeft"
                                   PlacementTarget="{Binding #FontSearchTextBox}"
                                   VerticalOffset="4">
                                <Border x:Name="FontPickerPopupContent"
                                    Width="280"
                                        MaxHeight="300"
                                        Background="#111318"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding FilteredAvailableFonts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding $parent[UserControl].DataContext.SelectFilteredFontCommand}"
                                                            CommandParameter="{Binding .}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Padding="8,6"
                                                            Margin="0,1,0,1">
                                                        <TextBlock Text="{Binding .}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource Accent}" />
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Color"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />

                        <Grid ColumnDefinitions="64,*"
                              ColumnSpacing="10">
                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    Background="{Binding SelectedColorPreviewBrush}" />
                            <StackPanel Grid.Column="1"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedColorHex}"
                                           Foreground="{DynamicResource Accent}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />

                                <ItemsControl ItemsSource="{Binding BasicColors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TextColorPreset">
                                            <Button Width="34"
                                                    Height="34"
                                                    Margin="0,0,8,8"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Command="{Binding $parent[UserControl].DataContext.SelectBasicColorCommand}"
                                                    CommandParameter="{Binding}">
                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        BorderBrush="{DynamicResource AccentSubtle}"
                                                        BorderThickness="1"
                                                        Background="{Binding ColorBrush}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Outline"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />

                        <Grid ColumnDefinitions="64,*"
                              ColumnSpacing="10">
                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    Background="{Binding SelectedOutlineColorPreviewBrush}" />
                            <StackPanel Grid.Column="1"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedOutlineColorHex}"
                                           Foreground="{DynamicResource Accent}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />

                                <ItemsControl ItemsSource="{Binding BasicColors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TextColorPreset">
                                            <Button Width="34"
                                                    Height="34"
                                                    Margin="0,0,8,8"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Command="{Binding $parent[UserControl].DataContext.SelectBasicOutlineColorCommand}"
                                                    CommandParameter="{Binding}">
                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        BorderBrush="{DynamicResource AccentSubtle}"
                                                        BorderThickness="1"
                                                        Background="{Binding ColorBrush}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Border Padding="10"
                            CornerRadius="8"
                            Background="#222222"
                            BorderBrush="{DynamicResource AccentSubtle}"
                            BorderThickness="1">
                        <Grid ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Outline"
                                           Foreground="{DynamicResource AccentMuted}"
                                           FontSize="12" />
                                <Border Padding="10,6"
                                        Background="#112EC4B6"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        HorizontalAlignment="Left"
                                        Cursor="SizeWestEast"
                                        PointerPressed="OutlineThicknessValue_OnPointerPressed"
                                        PointerMoved="OutlineThicknessValue_OnPointerMoved"
                                        PointerReleased="OutlineThicknessValue_OnPointerReleased"
                                        PointerCaptureLost="OutlineThicknessValue_OnPointerCaptureLost">
                                    <TextBlock Text="{Binding SelectedClipOutlineThickness, StringFormat='{}{0:F0}px'}"
                                               Foreground="{DynamicResource Accent}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="4">
                                <TextBlock Text="Size"
                                           Foreground="{DynamicResource AccentMuted}"
                                           FontSize="12" />
                                <Border Padding="10,6"
                                        Background="#112EC4B6"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        HorizontalAlignment="Left"
                                        Cursor="SizeWestEast"
                                        PointerPressed="SizeValue_OnPointerPressed"
                                        PointerMoved="SizeValue_OnPointerMoved"
                                        PointerReleased="SizeValue_OnPointerReleased"
                                        PointerCaptureLost="SizeValue_OnPointerCaptureLost">
                                    <TextBlock Text="{Binding SelectedClipFontSize, StringFormat='{}{0:F0}px'}"
                                               Foreground="{DynamicResource Accent}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Spacing="4">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <Canvas Width="16"
                                            Height="16">
                                        <Path Data="M2 5 L4 3 L6 5"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M2 11 L4 13 L6 11"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M4 2 L4 14"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M9 4 L14 4"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M9 8 L14 8"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M9 12 L14 12"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                    </Canvas>
                                    <TextBlock Text="Line height"
                                               Foreground="{DynamicResource AccentMuted}"
                                               FontSize="12" />
                                </StackPanel>
                                <Border Padding="10,6"
                                        Background="#112EC4B6"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        HorizontalAlignment="Left"
                                        Cursor="SizeWestEast"
                                        PointerPressed="LineHeightValue_OnPointerPressed"
                                        PointerMoved="LineHeightValue_OnPointerMoved"
                                        PointerReleased="LineHeightValue_OnPointerReleased"
                                        PointerCaptureLost="LineHeightValue_OnPointerCaptureLost">
                                    <TextBlock Text="{Binding SelectedClipLineHeightMultiplier, StringFormat='{}{0:F2}x'}"
                                               Foreground="{DynamicResource Accent}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Spacing="4">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <Canvas Width="16"
                                            Height="16">
                                        <Path Data="M3 8 V4.5 A2.5 2.5 0 0 1 8 4.5 V8"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round"
                                              Fill="Transparent" />
                                        <Path Data="M8 6 H3"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M10 3 L12 8 L14 3"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round"
                                              Fill="Transparent" />
                                        <Path Data="M3 12 H14"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round" />
                                        <Path Data="M12 14 L14 12 L12 10"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round"
                                              Fill="Transparent" />
                                        <Path Data="M5 10 L3 12 L5 14"
                                              Stroke="{DynamicResource AccentMuted}"
                                              StrokeThickness="1.5"
                                              StrokeLineCap="Round"
                                              Fill="Transparent" />
                                    </Canvas>
                                    <TextBlock Text="Letter spacing"
                                               Foreground="{DynamicResource AccentMuted}"
                                               FontSize="12" />
                                </StackPanel>
                                <Border Padding="10,6"
                                        Background="#112EC4B6"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        HorizontalAlignment="Left"
                                        Cursor="SizeWestEast"
                                        PointerPressed="LetterSpacingValue_OnPointerPressed"
                                        PointerMoved="LetterSpacingValue_OnPointerMoved"
                                        PointerReleased="LetterSpacingValue_OnPointerReleased"
                                        PointerCaptureLost="LetterSpacingValue_OnPointerCaptureLost">
                                    <TextBlock Text="{Binding SelectedClipLetterSpacing, StringFormat='{}{0:F1}px'}"
                                               Foreground="{DynamicResource Accent}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Spacing="4"
                                IsVisible="{Binding IsSubtitlesMode}">
                        <TextBlock Text="Subtitles effect"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <ComboBox ItemsSource="{Binding AvailableTextRevealEffects}"
                                  SelectedItem="{Binding SelectedClipTextRevealEffect, Mode=TwoWay}"
                                  Classes="accentInput"
                                  Width="180"
                                  HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Preset"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8">
                            <TextBox Text="{Binding NewPresetName, Mode=TwoWay}"
                                                                         Classes="accentInput"
                                     Watermark="Preset name (optional)" />
                                                        <commonViews:ActionButton Grid.Column="1"
                                                                                                            Label="{Binding SavePresetButtonLabel}"
                                                                                                            Command="{Binding SavePresetCommand}" />
                                                        <commonViews:ActionButton Grid.Column="2"
                                                                                  Label="{Binding DeletePresetButtonLabel}"
                                                                                                            Command="{Binding DeletePresetCommand}"
                                                                                                            IsVisible="{Binding IsEditingPreset}" />
                        </Grid>
                        <TextBlock Text="{Binding PresetSaveStatus}"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="11"
                                   IsVisible="{Binding HasPresetSaveStatus}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border IsVisible="{Binding IsSubtitlesBusy}"
                ZIndex="10"
                Background="#AA101413"
                CornerRadius="10"
                Padding="18"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="280"
                    MaxWidth="380"
                    Padding="16"
                    CornerRadius="10"
                    Background="#EE1B2520"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding SubtitlesLoadingTitle}"
                               Foreground="{DynamicResource Accent}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True"
                                 Height="6"
                                 IsVisible="{Binding IsApplyingSubtitles}" />
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{Binding TranscriptionProgress}"
                                 Height="6"
                                 IsVisible="{Binding IsTranscriptionProgressVisible}" />
                    <TextBlock Text="{Binding TranscriptionStatus}"
                               Foreground="{DynamicResource AccentMuted}"
                               FontSize="12"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>

</UserControl>
