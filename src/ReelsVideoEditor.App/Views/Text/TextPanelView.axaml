<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Text"
             xmlns:models="using:ReelsVideoEditor.App.Models"
             xmlns:commonViews="using:ReelsVideoEditor.App.Views.Common"
             x:Class="ReelsVideoEditor.App.Views.Text.TextPanelView"
             x:DataType="vm:TextViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12">
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsPresetVisible}">
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource Accent}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left" />
            <TextBlock Text="{Binding Description}"
                       Foreground="{DynamicResource AccentMuted}"
                       FontSize="13"
                       HorizontalAlignment="Left" />

            <ItemsControl ItemsSource="{Binding Presets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TextPresetDefinition">
                        <Border Width="154"
                                Height="108"
                                Margin="0,0,10,10"
                                Padding="10"
                                CornerRadius="10"
                                Background="#AA222222"
                                BorderBrush="{DynamicResource AccentSubtle}"
                                BorderThickness="1"
                                Cursor="Hand"
                                PointerPressed="PresetTile_OnPointerPressed">
                            <Grid RowDefinitions="Auto,*,Auto"
                                  RowSpacing="4">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource AccentMuted}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding DisplayText}"
                                           FontFamily="{Binding FontFamily}"
                                           FontSize="{Binding FontSize}"
                                           Foreground="{Binding ColorBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />

                                <Border Grid.Row="2"
                                        Height="8"
                                        CornerRadius="4"
                                        Background="{Binding ColorBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="12"
                        IsVisible="{Binding IsEditorVisible}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <commonViews:BackButton Command="{Binding BackToPresetsCommand}" />
                <StackPanel Grid.Column="1"
                            Spacing="2">
                    <TextBlock Text="{Binding EditorTitle}"
                               Foreground="{DynamicResource Accent}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding EditorDescription}"
                               Foreground="{DynamicResource AccentMuted}"
                               FontSize="12" />
                </StackPanel>
            </Grid>

            <Border Padding="12"
                    CornerRadius="10"
                    Background="#AA222222"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Text"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding SelectedClipText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 MinHeight="76" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Font"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding SelectedClipFontFamily, Mode=TwoWay}"
                                  Width="280"
                                  HorizontalAlignment="Left"
                                  MaxDropDownHeight="300">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}"
                                               Width="248"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Color"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />

                        <Grid ColumnDefinitions="64,*"
                              ColumnSpacing="10">
                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    Background="{Binding SelectedColorPreviewBrush}" />
                            <StackPanel Grid.Column="1"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedColorHex}"
                                           Foreground="{DynamicResource Accent}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />

                                <ItemsControl ItemsSource="{Binding BasicColors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TextColorPreset">
                                            <Button Width="34"
                                                    Height="34"
                                                    Margin="0,0,8,8"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Command="{Binding $parent[UserControl].DataContext.SelectBasicColorCommand}"
                                                    CommandParameter="{Binding}">
                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        BorderBrush="{DynamicResource AccentSubtle}"
                                                        BorderThickness="1"
                                                        Background="{Binding ColorBrush}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Size"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <Border Padding="10,6"
                                Background="#112EC4B6"
                                BorderBrush="{DynamicResource AccentSubtle}"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Left"
                                Cursor="SizeWestEast"
                                PointerPressed="SizeValue_OnPointerPressed"
                                PointerMoved="SizeValue_OnPointerMoved"
                                PointerReleased="SizeValue_OnPointerReleased"
                                PointerCaptureLost="SizeValue_OnPointerCaptureLost">
                            <TextBlock Text="{Binding SelectedClipFontSize, StringFormat='{}{0:F0}px'}"
                                       Foreground="{DynamicResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="Drag left/right to change size"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="11" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Preset"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <TextBox Text="{Binding NewPresetName, Mode=TwoWay}"
                                     Watermark="Preset name (optional)" />
                            <Button Grid.Column="1"
                                    Content="Save preset"
                                    Command="{Binding SavePresetCommand}"
                                    MinWidth="108"
                                    HorizontalAlignment="Right" />
                        </Grid>
                        <TextBlock Text="{Binding PresetSaveStatus}"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="11"
                                   IsVisible="{Binding HasPresetSaveStatus}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

</UserControl>
