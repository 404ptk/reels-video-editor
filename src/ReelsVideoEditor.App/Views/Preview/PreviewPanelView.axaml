<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Preview"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             x:Class="ReelsVideoEditor.App.Views.Preview.PreviewPanelView"
             x:DataType="vm:PreviewViewModel">

    <UserControl.Styles>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          ClipToBounds="True">
        <TextBlock Foreground="{DynamicResource AccentMuted}"
                   FontSize="12"
                   Text="{Binding Title}" />

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                ClipToBounds="True">
            <Grid x:Name="PreviewViewport"
                  ClipToBounds="True">
                <Border x:Name="PreviewFrame"
                        Width="216"
                        Height="384"
                        Background="#AA222222"
                        BorderBrush="{DynamicResource AccentSubtle}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid ClipToBounds="True">
                        <vlc:VideoView x:Name="PreviewVideoView"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       IsVisible="{Binding IsVideoVisible}" />

                        <Border Background="#000000"
                            Opacity="{Binding CurrentVideoDimOpacity}"
                            IsHitTestVisible="False"
                            IsVisible="{Binding IsVideoVisible}" />

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6"
                                    IsVisible="{Binding ShowPlaceholder}">
                            <TextBlock Text="{Binding PlaceholderTitle}"
                                       Foreground="{DynamicResource Accent}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding PlaceholderSubtitle}"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="11"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Spacing="6">
            <Grid HorizontalAlignment="Center"
                ColumnDefinitions="74,Auto,74">
                <TextBlock Text="{Binding CurrentPlaybackTimeText}"
                       Grid.Column="0"
                           Foreground="{DynamicResource AccentMuted}"
                       FontFamily="Consolas"
                           FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right" />
                <TextBlock Text="/"
                       Grid.Column="1"
                       Margin="4,0"
                           Foreground="{DynamicResource AccentSubtle}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding TotalPlaybackTimeText}"
                       Grid.Column="2"
                           Foreground="{DynamicResource AccentMuted}"
                       FontFamily="Consolas"
                           FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left" />
            </Grid>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
            <Button Width="42"
                    Height="36"
                    Classes="icon-btn"
                    Command="{Binding TogglePlayPauseCommand}"
                    ToolTip.Tip="Play / Pause">
                <Path Data="{Binding PlayPauseIconPath}"
                      Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Fill="{DynamicResource Accent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Button>

            <Button Width="42"
                    Height="36"
                    Classes="icon-btn"
                    Command="{Binding StopCommand}"
                    ToolTip.Tip="Stop">
                <Path Data="M4,4 H12 V12 H4 Z"
                      Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Fill="{DynamicResource Accent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
