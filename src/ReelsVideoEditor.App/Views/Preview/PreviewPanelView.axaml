<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Preview"
             xmlns:preview="using:ReelsVideoEditor.App.Views.Preview"
             x:Class="ReelsVideoEditor.App.Views.Preview.PreviewPanelView"
             x:DataType="vm:PreviewViewModel">

    <Grid RowDefinitions="Auto,*,Auto"
          ClipToBounds="True">
        <preview:PreviewTopBarView Grid.Row="0" />
        <preview:PreviewCanvasView x:Name="PreviewCanvas" Grid.Row="1" />
        <preview:PreviewTransportView Grid.Row="2" />
    </Grid>
</UserControl>
