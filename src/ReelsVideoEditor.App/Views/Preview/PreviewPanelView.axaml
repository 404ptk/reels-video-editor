<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Preview"
             x:Class="ReelsVideoEditor.App.Views.Preview.PreviewPanelView"
             x:DataType="vm:PreviewViewModel">

    <Grid RowDefinitions="Auto,*"
          ClipToBounds="True">
        <TextBlock Foreground="{DynamicResource AccentMuted}"
                   FontSize="12"
                   Text="{Binding Title}" />

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                ClipToBounds="True">
            <Viewbox Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Border Width="216"
                        Height="384"
                        CornerRadius="18"
                        Background="#AA222222"
                        BorderBrush="{DynamicResource AccentSubtle}"
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <TextBlock Text="{Binding PlaceholderTitle}"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PlaceholderSubtitle}"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Viewbox>
        </Border>
    </Grid>
</UserControl>
