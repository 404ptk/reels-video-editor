<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Preview"
             x:Class="ReelsVideoEditor.App.Views.Preview.PreviewPanelView"
             x:DataType="vm:PreviewViewModel">

    <UserControl.Styles>
        <Style Selector="Button.icon-btn">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ToggleButton.preview-tool">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{DynamicResource AccentMuted}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.preview-tool:pointerover">
            <Setter Property="Background" Value="#0AFFFFFF" />
        </Style>
        <Style Selector="ToggleButton.preview-tool:checked">
            <Setter Property="Background" Value="#15FFFFFF" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="BorderBrush" Value="#2AFFFFFF" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          ClipToBounds="True">
        <Grid ColumnDefinitions="1*,Auto,1*">
            <TextBlock Grid.Column="0"
                       Foreground="{DynamicResource AccentMuted}"
                       FontSize="12"
                       Text="{Binding Title}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center" />

            <Border Grid.Column="1" 
                    BorderBrush="{DynamicResource AccentSubtle}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="2" 
                    Background="#0Affffff" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <ToggleButton Classes="preview-tool" IsChecked="{Binding IsTransformModeEnabled, Mode=TwoWay}" ToolTip.Tip="Transform">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{Binding $parent[ToggleButton].Foreground}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M3 4a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -2 M17 4a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -2 M17 18a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -2 M11 5h2 M5 11v2 M19 11v2 M11 19h2" />
                                <Path Stroke="{Binding $parent[ToggleButton].Foreground}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="{Binding $parent[ToggleButton].Foreground}" Data="M3 18a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -2" />
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>
                    <ToggleButton Classes="preview-tool" IsChecked="{Binding IsClipperModeEnabled, Mode=TwoWay}" ToolTip.Tip="Clipper">
                        <Viewbox Width="22" Height="22">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{Binding $parent[ToggleButton].Foreground}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M8 5v10a1 1 0 0 0 1 1h10 M5 8h10a1 1 0 0 1 1 1v10" />
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="16"
                        VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding AvailableQualities}"
                          SelectedItem="{Binding SelectedQuality}"
                          VerticalAlignment="Center"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource AccentMuted}"
                          Background="Transparent"
                          BorderBrush="Transparent"
                          BorderThickness="0" />

                <StackPanel Orientation="Vertical"
                            Spacing="2"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsVideoVisible}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="6">
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{Binding FpsDotColor}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FpsText}"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding ZoomText}"
                               Foreground="{DynamicResource AccentMuted}"
                               FontSize="11"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                ClipToBounds="True">
            <Border Margin="16">
                <Grid x:Name="PreviewViewport"
                      ClipToBounds="False"
                      Background="Transparent">
                    
                    <Border x:Name="PreviewFrame"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ClipToBounds="False"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Border.RenderTransform>

                        <Panel IsVisible="{Binding IsVideoVisible}">
                            <Border BorderBrush="{DynamicResource AccentSubtle}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" Background="Black">
                                <Image x:Name="PreviewImage"
                                       Source="{Binding CurrentFrame}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" />
                            </Border>

                            <Grid Width="{Binding ScaledForegroundWidth}"
                                  Height="{Binding ScaledForegroundHeight}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False"
                                  IsVisible="{Binding IsTransformModeEnabled, Mode=OneWay}">
                                  
                                <Grid.RenderTransform>
                                    <TranslateTransform X="{Binding TransformX}" Y="{Binding TransformY}" />
                                </Grid.RenderTransform>
                                  
                                <Border BorderBrush="White" BorderThickness="{Binding TransformHandleThickness}" />
                                        
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="{Binding HandleMarginTopLeft}" />
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="{Binding HandleMarginTopRight}" />
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="{Binding HandleMarginBottomLeft}" />
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="{Binding HandleMarginBottomRight}" />
                                
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="{Binding HandleMarginTopCenter}" />
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="{Binding HandleMarginBottomCenter}" />
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{Binding HandleMarginLeftCenter}" />
                                <Ellipse Classes="TransformHandle" Cursor="Hand" Width="{Binding TransformHandleSize}" Height="{Binding TransformHandleSize}" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="{Binding HandleMarginRightCenter}" />
                            </Grid>
                        </Panel>
                    </Border>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="6"
                                IsVisible="{Binding ShowPlaceholder}">
                        <TextBlock Text="{Binding PlaceholderTitle}"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PlaceholderSubtitle}"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <StackPanel Grid.Row="2"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Spacing="6">
            <Grid HorizontalAlignment="Center"
                ColumnDefinitions="74,Auto,74">
                <TextBlock Text="{Binding CurrentPlaybackTimeText}"
                       Grid.Column="0"
                           Foreground="{DynamicResource AccentMuted}"
                       FontFamily="Consolas"
                           FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right" />
                <TextBlock Text="/"
                       Grid.Column="1"
                       Margin="4,0"
                           Foreground="{DynamicResource AccentSubtle}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding TotalPlaybackTimeText}"
                       Grid.Column="2"
                           Foreground="{DynamicResource AccentMuted}"
                       FontFamily="Consolas"
                           FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left" />
            </Grid>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
            <Button Width="42"
                    Height="36"
                    Classes="icon-btn"
                    Command="{Binding TogglePlayPauseCommand}"
                    ToolTip.Tip="Play / Pause">
                <Path Data="{Binding PlayPauseIconPath}"
                      Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Fill="{DynamicResource Accent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Button>

            <Button Width="42"
                    Height="36"
                    Classes="icon-btn"
                    Command="{Binding StopCommand}"
                    ToolTip.Tip="Stop">
                <Path Data="M4,4 H12 V12 H4 Z"
                      Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Fill="{DynamicResource Accent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
