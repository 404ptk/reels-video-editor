<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Preview"
             x:Class="ReelsVideoEditor.App.Views.Preview.PreviewPanelView"
             x:DataType="vm:PreviewViewModel">

    <UserControl.Styles>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          ClipToBounds="True">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Foreground="{DynamicResource AccentMuted}"
                       FontSize="12"
                       Text="{Binding Title}"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsVideoVisible}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="6">
                    <Ellipse Width="8"
                             Height="8"
                             Fill="{Binding FpsDotColor}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FpsText}"
                               Foreground="{DynamicResource AccentMuted}"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding ZoomText}"
                           Foreground="{DynamicResource AccentMuted}"
                           FontSize="11"
                           HorizontalAlignment="Right" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                ClipToBounds="True">
            <Grid x:Name="PreviewViewport"
                  ClipToBounds="True"
                  Background="Transparent">
                <Border x:Name="PreviewFrame"
                        Width="216"
                        Height="384"
                    Background="#000000"
                        BorderBrush="{DynamicResource AccentSubtle}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="50%,50%">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                            <TranslateTransform X="0" Y="0" />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid ClipToBounds="True">
                        <Image x:Name="PreviewImage"
                               Source="{Binding CurrentFrame}"
                               Stretch="Uniform"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               IsVisible="{Binding IsVideoVisible}" />



                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6"
                                    IsVisible="{Binding ShowPlaceholder}">
                            <TextBlock Text="{Binding PlaceholderTitle}"
                                       Foreground="{DynamicResource Accent}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding PlaceholderSubtitle}"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="11"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Spacing="6">
            <Grid HorizontalAlignment="Center"
                ColumnDefinitions="74,Auto,74">
                <TextBlock Text="{Binding CurrentPlaybackTimeText}"
                       Grid.Column="0"
                           Foreground="{DynamicResource AccentMuted}"
                       FontFamily="Consolas"
                           FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right" />
                <TextBlock Text="/"
                       Grid.Column="1"
                       Margin="4,0"
                           Foreground="{DynamicResource AccentSubtle}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding TotalPlaybackTimeText}"
                       Grid.Column="2"
                           Foreground="{DynamicResource AccentMuted}"
                       FontFamily="Consolas"
                           FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left" />
            </Grid>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
            <Button Width="42"
                    Height="36"
                    Classes="icon-btn"
                    Command="{Binding TogglePlayPauseCommand}"
                    ToolTip.Tip="Play / Pause">
                <Path Data="{Binding PlayPauseIconPath}"
                      Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Fill="{DynamicResource Accent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Button>

            <Button Width="42"
                    Height="36"
                    Classes="icon-btn"
                    Command="{Binding StopCommand}"
                    ToolTip.Tip="Stop">
                <Path Data="M4,4 H12 V12 H4 Z"
                      Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Fill="{DynamicResource Accent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
