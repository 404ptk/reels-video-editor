<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Watermarks"
             xmlns:models="using:ReelsVideoEditor.App.Models"
             xmlns:commonViews="using:ReelsVideoEditor.App.Views.Common"
             x:Class="ReelsVideoEditor.App.Views.Watermarks.WatermarksPanelView"
             x:DataType="vm:WatermarksViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.accentInput">
            <Setter Property="Background" Value="#111318" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="TextBox.accentInput:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="TextBox.accentInput:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="Button.presetIconBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Foreground" Value="{DynamicResource AccentMuted}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.presetIconBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="StackPanel.presetActions">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="Border.presetTile:pointerover StackPanel.presetActions">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12">
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsPresetVisible}">
                <TextBlock Text="{Binding Title}"
                           Foreground="{DynamicResource Accent}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Description}"
                           Foreground="{DynamicResource AccentMuted}"
                           FontSize="13"
                           HorizontalAlignment="Left" />

                <ItemsControl ItemsSource="{Binding PresetTiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:WatermarkPresetDefinition">
                            <Border Width="154"
                                    Height="112"
                                    Margin="0,0,10,10"
                                    Classes="presetTile"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="#AA222222"
                                    BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    PointerEntered="PresetTile_OnPointerEntered"
                                    PointerPressed="PresetTile_OnPointerPressed">
                                <Grid>
                                    <Grid RowDefinitions="Auto,*,Auto"
                                          RowSpacing="4"
                                          IsVisible="{Binding IsRegularTile}">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="4"
                                              MinHeight="22">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource AccentMuted}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <StackPanel Grid.Column="1"
                                                        Classes="presetActions"
                                                        Orientation="Horizontal"
                                                        Spacing="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                <Button Classes="presetIconBtn"
                                                        Command="{Binding $parent[UserControl].DataContext.EditPresetFromTileCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Data="M4 20h4l10.5 -10.5a2.828 2.828 0 1 0 -4 -4l-10.5 10.5v4 M13.5 6.5l4 4"
                                                          Width="12"
                                                          Height="12"
                                                          Stretch="Uniform"
                                                          StrokeThickness="2"
                                                          StrokeLineCap="Round"
                                                          Stroke="{Binding $parent[Button].Foreground}" />
                                                </Button>

                                                <Button Classes="presetIconBtn"
                                                        Command="{Binding $parent[UserControl].DataContext.DeletePresetFromTileCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Data="M4 7l16 0 M10 11l0 6 M14 11l0 6 M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12 M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"
                                                          Width="12"
                                                          Height="12"
                                                          Stretch="Uniform"
                                                          StrokeThickness="2"
                                                          StrokeLineCap="Round"
                                                          Stroke="{Binding $parent[Button].Foreground}" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <Border Grid.Row="1"
                                                Background="#12000000"
                                                BorderBrush="{DynamicResource AccentSubtle}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Height="56"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ClipToBounds="True">
                                            <Image Source="{Binding PreviewImage}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Border>

                                    </Grid>

                                    <Button IsVisible="{Binding IsAddTile}"
                                            Command="{Binding $parent[UserControl].DataContext.CreatePresetFromTileCommand}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Padding="0"
                                            Cursor="Hand">
                                        <StackPanel VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Spacing="8">
                                            <Path Data="M12 5l0 14 M5 12l14 0"
                                                  Width="26"
                                                  Height="26"
                                                  Stretch="Uniform"
                                                  Fill="Transparent"
                                                  Stroke="{DynamicResource AccentMuted}"
                                                  StrokeThickness="2"
                                                  StrokeLineCap="Round"
                                                  StrokeJoin="Round"
                                                  HorizontalAlignment="Center" />
                                            <TextBlock Text="New preset"
                                                       Foreground="{DynamicResource AccentMuted}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="12"
                        IsVisible="{Binding IsEditorVisible}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <commonViews:BackButton Command="{Binding BackToPresetsCommand}" />
                    <StackPanel Grid.Column="1"
                                Spacing="2">
                        <TextBlock Text="{Binding EditorTitle}"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding EditorDescription}"
                                   Foreground="{DynamicResource AccentMuted}"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>

                <Border Padding="12"
                        CornerRadius="10"
                        Background="#AA222222"
                        BorderBrush="{DynamicResource AccentSubtle}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Watermark image"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="12" />
                            <Border Height="130"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    Background="#12000000"
                                    ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding SelectedImagePreview}"
                                           Stretch="Uniform"
                                           IsVisible="{Binding HasSelectedImage}" />
                                    <TextBlock Text="No image selected"
                                               Foreground="{DynamicResource AccentMuted}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !HasSelectedImage}" />
                                </Grid>
                            </Border>

                                <commonViews:ActionButton Label="Load image from computer"
                                                          ButtonWidth="210"
                                                          LabelHorizontalAlignment="Left"
                                                          HorizontalAlignment="Left"
                                                          PointerPressed="LoadImageActionButton_OnPointerPressed" />

                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Opacity"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="12" />
                            <Border Padding="10,6"
                                    Background="#112EC4B6"
                                    BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left"
                                    Cursor="SizeWestEast"
                                    PointerPressed="OpacityValue_OnPointerPressed"
                                    PointerMoved="OpacityValue_OnPointerMoved"
                                    PointerReleased="OpacityValue_OnPointerReleased"
                                    PointerCaptureLost="OpacityValue_OnPointerCaptureLost">
                                <TextBlock Text="{Binding SelectedOpacityPercent}"
                                           Foreground="{DynamicResource Accent}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Preset"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="12" />
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <TextBox Text="{Binding NewPresetName, Mode=TwoWay}"
                                                                                 Classes="accentInput"
                                         Watermark="Preset name (optional)" />
                                <commonViews:ActionButton Grid.Column="1"
                                                          Label="{Binding SavePresetButtonLabel}"
                                                          Command="{Binding SavePresetCommand}" />
                                <commonViews:ActionButton Grid.Column="2"
                                                          Label="{Binding DeletePresetButtonLabel}"
                                                          Command="{Binding DeletePresetCommand}"
                                                          IsVisible="{Binding IsEditingPreset}" />
                            </Grid>

                            <TextBlock Text="{Binding PresetSaveStatus}"
                                       Foreground="{DynamicResource AccentMuted}"
                                       FontSize="11"
                                       IsVisible="{Binding HasPresetSaveStatus}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

</UserControl>
