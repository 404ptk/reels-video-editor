<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.VideoFiles"
             x:Class="ReelsVideoEditor.App.Views.VideoFiles.VideoFilesPanelView"
             x:DataType="vm:VideoFilesViewModel">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Foreground="{DynamicResource AccentMuted}"
                   FontSize="12"
                   Text="{Binding Title}" />

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="12"
                CornerRadius="10"
                Background="#AA222222"
                BorderBrush="{DynamicResource AccentSubtle}"
                BorderThickness="1"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="DropZone_OnDragOver"
                DragDrop.Drop="DropZone_OnDrop">
            <Grid>
                <StackPanel x:Name="DropHints"
                        Spacing="12"
                        VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding NoFiles}">
                    <TextBlock Text="{Binding DropHintTitle}"
                               Foreground="{DynamicResource Accent}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />

                    <TextBlock Text="{Binding DropHintSubtitle}"
                               Foreground="{DynamicResource AccentMuted}"
                           FontSize="13"
                           HorizontalAlignment="Center" />
                </StackPanel>

                <ScrollViewer IsVisible="{Binding HasFiles}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Files}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:VideoFileItem">
                                <Border Margin="0,0,10,10"
                                        Padding="8"
                                        Width="140"
                                        Height="140"
                                        CornerRadius="8"
                                        Background="#55222222"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                    BorderThickness="1"
                                    PointerPressed="FileTile_OnPointerPressed">
                                    <Grid RowDefinitions="*,Auto,Auto"
                                          RowSpacing="8">
                                        <Border CornerRadius="6"
                                                Background="#99222222"
                                                BorderBrush="{DynamicResource AccentSubtle}"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="VIDEO"
                                                           Foreground="{DynamicResource AccentMuted}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />

                                                <Image Source="{Binding Thumbnail}"
                                                          Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding Name}"
                                                   Grid.Row="1"
                                                   Foreground="{DynamicResource Accent}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
