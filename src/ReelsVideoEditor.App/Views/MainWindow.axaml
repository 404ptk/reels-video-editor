<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReelsVideoEditor.App.ViewModels"
        xmlns:local="using:ReelsVideoEditor.App.Views"
        xmlns:previewViews="using:ReelsVideoEditor.App.Views.Preview"
        xmlns:videoFilesViews="using:ReelsVideoEditor.App.Views.VideoFiles"
        xmlns:effectsViews="using:ReelsVideoEditor.App.Views.Effects"
        xmlns:textViews="using:ReelsVideoEditor.App.Views.Text"
        xmlns:watermarksViews="using:ReelsVideoEditor.App.Views.Watermarks"
        xmlns:exportViews="using:ReelsVideoEditor.App.Views.Export"
        xmlns:commonViews="using:ReelsVideoEditor.App.Views.Common"
        xmlns:timelineViews="using:ReelsVideoEditor.App.Views.Timeline"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="ReelsVideoEditor.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Reels Video Editor">

    <Window.Resources>
        <SolidColorBrush x:Key="BaseBg" Color="#222222" />
        <SolidColorBrush x:Key="BaseBgSoft" Color="#DD222222" />
        <SolidColorBrush x:Key="Accent" Color="#C2D8C4" />
        <SolidColorBrush x:Key="AccentMuted" Color="#99C2D8C4" />
        <SolidColorBrush x:Key="AccentSubtle" Color="#33C2D8C4" />
        <local:BoolToBackgroundConverter x:Key="ActiveSectionBgConverter" />
        <local:BoolToForegroundConverter x:Key="ActiveSectionFgConverter" />
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Background="{StaticResource BaseBg}">
        <Grid IsVisible="{Binding IsEditorLayoutVisible}">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="140" />
                <RowDefinition Height="8" />
                <RowDefinition Height="2*" MinHeight="140" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="16,16,16,8"
                    CornerRadius="16"
                    Background="{StaticResource BaseBgSoft}"
                    BorderBrush="{StaticResource AccentSubtle}"
                    BorderThickness="1"
                    Padding="12">
                <Grid ColumnDefinitions="92,12,*,12,1.15*">
                    <Border Grid.Column="0"
                            CornerRadius="10"
                            Background="{StaticResource BaseBg}"
                            BorderBrush="{StaticResource AccentSubtle}"
                            BorderThickness="1"
                            Padding="8">
                        <StackPanel Spacing="8"
                                    VerticalAlignment="Stretch">
                            <Button Height="56"
                                    HorizontalAlignment="Stretch"
                                    Background="{Binding IsExplorerSection, Converter={StaticResource ActiveSectionBgConverter}}"
                                    BorderBrush="{StaticResource AccentSubtle}"
                                    BorderThickness="1"
                                    Command="{Binding ShowExplorerCommand}">
                                  <Path Data="M5 4h4l3 3h7a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2"
                                      Width="20"
                                      Height="20"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{Binding IsExplorerSection, Converter={StaticResource ActiveSectionFgConverter}}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Button>

                            <Button Height="56"
                                    HorizontalAlignment="Stretch"
                                    Background="{Binding IsEffectsSection, Converter={StaticResource ActiveSectionBgConverter}}"
                                    BorderBrush="{StaticResource AccentSubtle}"
                                    BorderThickness="1"
                                    Command="{Binding ShowEffectsCommand}">
                                  <Path Data="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0 M13 12h5 M13 15h4 M13 18h1 M13 9h4 M13 6h1"
                                      Width="20"
                                      Height="20"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{Binding IsEffectsSection, Converter={StaticResource ActiveSectionFgConverter}}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Button>

                            <Button Height="56"
                                    HorizontalAlignment="Stretch"
                                    Background="{Binding IsWatermarksSection, Converter={StaticResource ActiveSectionBgConverter}}"
                                    BorderBrush="{StaticResource AccentSubtle}"
                                    BorderThickness="1"
                                    Command="{Binding ShowWatermarksCommand}">
                                  <Path Data="M3 7c3 -2 6 -2 9 0s6 2 9 0 M3 12c3 -2 6 -2 9 0s6 2 9 0 M3 17c3 -2 6 -2 9 0s6 2 9 0"
                                      Width="20"
                                      Margin="0,4,0,0"
                                      Height="20"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{Binding IsWatermarksSection, Converter={StaticResource ActiveSectionFgConverter}}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Button>

                                    <Button Height="56"
                                        HorizontalAlignment="Stretch"
                                        Background="{Binding IsTextSection, Converter={StaticResource ActiveSectionBgConverter}}"
                                        BorderBrush="{StaticResource AccentSubtle}"
                                        BorderThickness="1"
                                        Command="{Binding ShowTextCommand}">
                                      <Path Data="M3 7v-2h13v2 M10 5v14 M12 19h-4 M15 13v-1h6v1 M18 12v7 M17 19h2"
                                          Width="20"
                                          Height="20"
                                          Margin= "0,4,0,0"
                                          Stretch="Uniform"
                                          Fill="Transparent"
                                          Stroke="{Binding IsTextSection, Converter={StaticResource ActiveSectionFgConverter}}"
                                          StrokeThickness="2"
                                          StrokeLineCap="Round"
                                          StrokeJoin="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                    </Button>

                            <Button Height="56"
                                    HorizontalAlignment="Stretch"
                                    Background="{Binding IsExportSection, Converter={StaticResource ActiveSectionBgConverter}}"
                                    BorderBrush="{StaticResource AccentSubtle}"
                                    BorderThickness="1"
                                    Command="{Binding ShowExportCommand}">
                                                                    <Path Data="M21 3l-6.5 18a.55 .55 0 0 1 -1 0l-3.5 -7l-7 -3.5a.55 .55 0 0 1 0 -1l18 -6.5"
                                      Width="20"
                                      Height="20"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{Binding IsExportSection, Converter={StaticResource ActiveSectionFgConverter}}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            CornerRadius="10"
                            Background="{StaticResource BaseBg}"
                            BorderBrush="{StaticResource AccentSubtle}"
                            BorderThickness="1"
                            Padding="12">
                        <Grid>
                            <Border IsVisible="{Binding IsExplorerSection}"
                                    CornerRadius="8"
                                    Background="{StaticResource BaseBg}">
                                <videoFilesViews:VideoFilesPanelView DataContext="{Binding VideoFiles}" />
                            </Border>

                            <Border IsVisible="{Binding IsEffectsSection}"
                                    CornerRadius="8"
                                    Background="{StaticResource BaseBg}">
                                <effectsViews:EffectsPanelView DataContext="{Binding Effects}" />
                            </Border>

                            <Border IsVisible="{Binding IsWatermarksSection}"
                                    CornerRadius="8"
                                    Background="{StaticResource BaseBg}">
                                <watermarksViews:WatermarksPanelView DataContext="{Binding Watermarks}" />
                            </Border>

                            <Border IsVisible="{Binding IsTextSection}"
                                    CornerRadius="8"
                                    Background="{StaticResource BaseBg}">
                                <textViews:TextPanelView DataContext="{Binding Text}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4"
                            MinWidth="300"
                            Background="{StaticResource BaseBg}"
                            BorderBrush="{StaticResource AccentSubtle}"
                            BorderThickness="1"
                            Padding="12">
                        <previewViews:PreviewPanelView DataContext="{Binding Preview}" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1"
                          Margin="16,0"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="{StaticResource AccentSubtle}" />

            <Border Grid.Row="2"
                    Margin="16,8,16,16"
                    Padding="14"
                    CornerRadius="16"
                    Background="{StaticResource BaseBgSoft}"
                    BorderBrush="{StaticResource AccentSubtle}"
                    BorderThickness="1">
                <timelineViews:TimelinePanelView DataContext="{Binding Timeline}" />
            </Border>
        </Grid>

        <Border IsVisible="{Binding IsExportSection}"
                Margin="16"
                Padding="16"
                CornerRadius="16"
                Background="{StaticResource BaseBgSoft}"
                BorderBrush="{StaticResource AccentSubtle}"
                BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
                <DockPanel LastChildFill="False"
                           Margin="0,0,0,12">
                                        <commonViews:BackButton Command="{Binding ShowExplorerCommand}"
                                                                                        HorizontalAlignment="Right"
                                                                                        DockPanel.Dock="Right" />
                </DockPanel>

                <Border Grid.Row="1"
                        CornerRadius="10"
                        Background="{StaticResource BaseBg}"
                        BorderBrush="{StaticResource AccentSubtle}"
                        BorderThickness="1"
                        Padding="12">
                    <exportViews:ExportPanelView DataContext="{Binding Export}" />
                </Border>
            </Grid>
        </Border>
    </Grid>

</Window>
