<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReelsVideoEditor.App.ViewModels"
        xmlns:previewViews="using:ReelsVideoEditor.App.Views.Preview"
        xmlns:videoFilesViews="using:ReelsVideoEditor.App.Views.VideoFiles"
        xmlns:timelineViews="using:ReelsVideoEditor.App.Views.Timeline"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="ReelsVideoEditor.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Reels Video Editor">

    <Window.Resources>
        <SolidColorBrush x:Key="BaseBg" Color="#222222" />
        <SolidColorBrush x:Key="BaseBgSoft" Color="#DD222222" />
        <SolidColorBrush x:Key="Accent" Color="#C2D8C4" />
        <SolidColorBrush x:Key="AccentMuted" Color="#99C2D8C4" />
        <SolidColorBrush x:Key="AccentSubtle" Color="#33C2D8C4" />
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Space" Command="{Binding Preview.TogglePlayPauseCommand}" />
    </Window.KeyBindings>

    <Grid Background="{StaticResource BaseBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" MinHeight="140" />
            <RowDefinition Height="8" />
            <RowDefinition Height="2*" MinHeight="140" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,8"
                CornerRadius="16"
                Background="{StaticResource BaseBgSoft}"
                BorderBrush="{StaticResource AccentSubtle}"
                BorderThickness="1"
                Padding="12">
            <Grid ColumnDefinitions="*,12,360">
                <Border Grid.Column="0"
                        CornerRadius="10"
                        Background="{StaticResource BaseBg}"
                        BorderBrush="{StaticResource AccentSubtle}"
                        BorderThickness="1"
                        Padding="12">
                    <videoFilesViews:VideoFilesPanelView DataContext="{Binding VideoFiles}" />
                </Border>

                <Border Grid.Column="2"
                        CornerRadius="10"
                        Background="{StaticResource BaseBg}"
                        BorderBrush="{StaticResource AccentSubtle}"
                        BorderThickness="1"
                        Padding="12">
                    <previewViews:PreviewPanelView DataContext="{Binding Preview}" />
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Margin="16,0"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Background="{StaticResource AccentSubtle}" />

        <Border Grid.Row="2"
                Margin="16,8,16,16"
                Padding="14"
                CornerRadius="16"
                Background="{StaticResource BaseBgSoft}"
                BorderBrush="{StaticResource AccentSubtle}"
                BorderThickness="1">
            <timelineViews:TimelinePanelView DataContext="{Binding Timeline}" />
        </Border>
    </Grid>

</Window>
