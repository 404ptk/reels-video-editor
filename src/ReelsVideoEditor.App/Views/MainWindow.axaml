<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReelsVideoEditor.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="ReelsVideoEditor.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Reels Video Editor">

    <Window.Resources>
        <SolidColorBrush x:Key="BaseBg" Color="#222222" />
        <SolidColorBrush x:Key="BaseBgSoft" Color="#DD222222" />
        <SolidColorBrush x:Key="Accent" Color="#C2D8C4" />
        <SolidColorBrush x:Key="AccentMuted" Color="#99C2D8C4" />
        <SolidColorBrush x:Key="AccentSubtle" Color="#33C2D8C4" />
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Background="{StaticResource BaseBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" MinHeight="140" />
            <RowDefinition Height="8" />
            <RowDefinition Height="2*" MinHeight="140" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,8"
                CornerRadius="16"
                Background="{StaticResource BaseBgSoft}"
                BorderBrush="{StaticResource AccentSubtle}"
                BorderThickness="1"
                Padding="12">
            <Grid ColumnDefinitions="*,12,360">
                <Border Grid.Column="0"
                        CornerRadius="10"
                        Background="{StaticResource BaseBg}"
                        BorderBrush="{StaticResource AccentSubtle}"
                        BorderThickness="1" />

                <Border Grid.Column="2"
                        CornerRadius="10"
                        Background="{StaticResource BaseBg}"
                        BorderBrush="{StaticResource AccentSubtle}"
                        BorderThickness="1"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*"
                          ClipToBounds="True">
                        <TextBlock Foreground="{StaticResource AccentMuted}"
                                   FontSize="12"
                                   Text="Preview" />

                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                ClipToBounds="True">
                            <Viewbox Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Border Width="216"
                                        Height="384"
                                        CornerRadius="18"
                                        Background="#AA222222"
                                        BorderBrush="{StaticResource AccentSubtle}"
                                        BorderThickness="1" />
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Margin="16,0"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Background="{StaticResource AccentSubtle}" />

        <Border Grid.Row="2"
                Margin="16,8,16,16"
                Padding="14"
                CornerRadius="16"
                Background="{StaticResource BaseBgSoft}"
                BorderBrush="{StaticResource AccentSubtle}"
                BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          PointerWheelChanged="TimelineScrollViewer_OnPointerWheelChanged">
                <StackPanel Spacing="10">
                    <Border Height="52"
                            Width="{Binding TimelineCanvasWidth}"
                            HorizontalAlignment="Left"
                            Background="{StaticResource BaseBg}"
                            BorderBrush="{StaticResource AccentSubtle}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid RowDefinitions="18,*">
                            <ItemsControl ItemsSource="{Binding MinorTicks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding $parent[Window].DataContext.TickWidth}"
                                              Height="18">
                                            <Border Width="1"
                                                    Height="14"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    IsVisible="{Binding ShowLine}"
                                                    Background="{StaticResource AccentSubtle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl Grid.Row="1"
                                          ItemsSource="{Binding MajorTicks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}"
                                              Height="34">
                                            <TextBlock Margin="3,3,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AccentMuted}"
                                                       Text="{Binding Label}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Height="72"
                            Width="{Binding TimelineCanvasWidth}"
                            HorizontalAlignment="Left"
                            Background="{StaticResource BaseBg}"
                            BorderBrush="{StaticResource AccentSubtle}"
                            BorderThickness="1"
                            CornerRadius="8" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>

</Window>
