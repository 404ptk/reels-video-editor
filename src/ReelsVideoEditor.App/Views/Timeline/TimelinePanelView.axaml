<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Timeline"
             xmlns:arrangementVm="using:ReelsVideoEditor.App.ViewModels.Timeline.Arrangement"
             x:Class="ReelsVideoEditor.App.Views.Timeline.TimelinePanelView"
             x:DataType="vm:TimelineViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  PointerWheelChanged="TimelineScrollViewer_OnPointerWheelChanged">
        <Grid Width="{Binding TimelineCanvasWidth}"
                            Height="198"
              HorizontalAlignment="Left">
            <Border Height="52"
                    VerticalAlignment="Top"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="TimelineSeekSurface_OnPointerPressed">
                <Grid RowDefinitions="18,*">
                    <ItemsControl ItemsSource="{Binding MinorTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding $parent[UserControl].DataContext.TickWidth}"
                                      Height="18">
                                    <Border Width="1"
                                            Height="14"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            IsVisible="{Binding ShowLine}"
                                            Background="{DynamicResource AccentSubtle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding MajorTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding Width}"
                                      Height="34">
                                    <TextBlock Margin="3,3,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentMuted}"
                                               Text="{Binding Label}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Height="64"
                    VerticalAlignment="Top"
                    Margin="0,62,0,0"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="TimelineSeekSurface_OnPointerPressed"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TimelineTrack_OnDragOver"
                    DragDrop.Drop="TimelineTrack_OnDrop">
                <Grid ClipToBounds="True"
                      RowDefinitions="18,*">
                    <TextBlock Margin="8,2,0,0"
                               Text="Video"
                               FontSize="10"
                               Foreground="{DynamicResource AccentMuted}"
                               FontWeight="SemiBold" />

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding VideoClips}"
                                  Width="{Binding TimelineCanvasWidth}"
                                  Height="46"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="arrangementVm:TimelineClipItem">
                                <Border Canvas.Left="{Binding Left}"
                                        Width="{Binding Width}"
                                        Height="34"
                                        Margin="10,6,0,6"
                                        CornerRadius="6"
                                        Background="#66C2D8C4"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1">
                                    <TextBlock Margin="8,0"
                                               VerticalAlignment="Center"
                                               Foreground="#222222"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Height="64"
                    VerticalAlignment="Top"
                    Margin="0,134,0,0"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="TimelineSeekSurface_OnPointerPressed"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TimelineTrack_OnDragOver"
                    DragDrop.Drop="TimelineTrack_OnDrop">
                <Grid ClipToBounds="True"
                      RowDefinitions="18,*">
                    <TextBlock Margin="8,2,0,0"
                               Text="Audio"
                               FontSize="10"
                               Foreground="{DynamicResource AccentMuted}"
                               FontWeight="SemiBold" />

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding AudioClips}"
                                  Width="{Binding TimelineCanvasWidth}"
                                  Height="46"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="arrangementVm:TimelineClipItem">
                                <Border Canvas.Left="{Binding Left}"
                                        Width="{Binding Width}"
                                        Height="34"
                                        Margin="10,6,0,6"
                                        CornerRadius="6"
                                        Background="#4D94A6FF"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Margin="8,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#222222"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Text="♪" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#222222"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Width="2"
                    Height="198"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Accent}"
                    IsHitTestVisible="False"
                    IsVisible="{Binding IsPlayheadVisible}">
                <Border.RenderTransform>
                    <TranslateTransform X="{Binding PlayheadVisualLeft}" />
                </Border.RenderTransform>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
