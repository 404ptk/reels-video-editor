<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Timeline"
             xmlns:arrangementVm="using:ReelsVideoEditor.App.ViewModels.Timeline.Arrangement"
             x:Class="ReelsVideoEditor.App.Views.Timeline.TimelinePanelView"
             x:DataType="vm:TimelineViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  PointerWheelChanged="TimelineScrollViewer_OnPointerWheelChanged">
        <StackPanel Spacing="10">
            <Border Height="52"
                    Width="{Binding TimelineCanvasWidth}"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid RowDefinitions="18,*">
                    <ItemsControl ItemsSource="{Binding MinorTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding $parent[UserControl].DataContext.TickWidth}"
                                      Height="18">
                                    <Border Width="1"
                                            Height="14"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            IsVisible="{Binding ShowLine}"
                                            Background="{DynamicResource AccentSubtle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding MajorTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding Width}"
                                      Height="34">
                                    <TextBlock Margin="3,3,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentMuted}"
                                               Text="{Binding Label}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Height="72"
                    Width="{Binding TimelineCanvasWidth}"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TimelineTrack_OnDragOver"
                    DragDrop.Drop="TimelineTrack_OnDrop">
                <Grid ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding Clips}"
                                  Width="{Binding TimelineCanvasWidth}"
                                  Height="72"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="arrangementVm:TimelineClipItem">
                                <Border Canvas.Left="{Binding Left}"
                                        Width="{Binding Width}"
                                        Height="52"
                                        Margin="10,10,0,10"
                                        CornerRadius="6"
                                        Background="#66C2D8C4"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1">
                                    <TextBlock Margin="8,0"
                                               VerticalAlignment="Center"
                                               Foreground="#222222"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Width="2"
                            Height="72"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource Accent}"
                            IsHitTestVisible="False"
                            IsVisible="{Binding IsPlayheadVisible}">
                        <Border.RenderTransform>
                            <TranslateTransform X="{Binding PlayheadVisualLeft}" />
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
