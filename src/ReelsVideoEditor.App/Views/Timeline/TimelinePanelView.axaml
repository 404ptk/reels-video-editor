<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Timeline"
             xmlns:arrangementVm="using:ReelsVideoEditor.App.ViewModels.Timeline.Arrangement"
             x:Class="ReelsVideoEditor.App.Views.Timeline.TimelinePanelView"    
             x:DataType="vm:TimelineViewModel"
             Focusable="True">

    <Grid ColumnDefinitions="96,8,*">
      <Grid Grid.Column="0"
            Height="{Binding TimelineCanvasHeight}"
            RowDefinitions="52,10,Auto,8,Auto"
            HorizontalAlignment="Stretch">
          <Border Grid.Row="2"
                  Height="{Binding LaneContainerHeight}"
                  Background="{DynamicResource AccentSubtle}"
                  BorderBrush="{DynamicResource AccentSubtle}"
                  BorderThickness="1"
                  CornerRadius="8">
              <Grid RowDefinitions="18,*">
                  <TextBlock Grid.Row="0"
                             Text="VIDEO"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Foreground="{DynamicResource AccentMuted}"
                             FontSize="10"
                             FontWeight="SemiBold" />
                  <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                      <ToggleButton IsChecked="{Binding IsVideoSolo}"
                                    Focusable="False"
                                    Width="24" Height="22"
                                    CornerRadius="4"
                                    Padding="0">
                          <ToggleButton.Styles>
                              <Style Selector="ToggleButton">
                                  <Setter Property="HorizontalContentAlignment" Value="Center" />
                                  <Setter Property="VerticalContentAlignment" Value="Center" />
                                  <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                  <Setter Property="Background" Value="{DynamicResource BaseBg}" />
                                  <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="ToggleButton:checked">
                                  <Setter Property="Foreground" Value="{DynamicResource BaseBg}" />
                                  <Setter Property="Background" Value="{DynamicResource Accent}" />
                              </Style>
                          </ToggleButton.Styles>
                          <TextBlock Text="S" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0" />
                      </ToggleButton>
                      <ToggleButton IsChecked="{Binding IsVideoHidden}"
                                    Focusable="False"
                                    Width="24" Height="22"
                                    CornerRadius="4"
                                    Padding="0">
                          <ToggleButton.Styles>
                              <Style Selector="ToggleButton">
                                  <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                  <Setter Property="Background" Value="{DynamicResource BaseBg}" />
                                  <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="ToggleButton:checked">
                                  <Setter Property="Foreground" Value="#FFF" />
                                  <Setter Property="Background" Value="#A04040" />
                              </Style>
                          </ToggleButton.Styles>
                          <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <Canvas Width="24" Height="24">
                                  <Path Data="M17,10.5L21,6.5V17.5L17,13.5V17A1,1 0 0,1 16,18H4A1,1 0 0,1 3,17V7A1,1 0 0,1 4,6H16A1,1 0 0,1 17,7Z" Fill="{Binding $parent[ToggleButton].Foreground}" />
                                  <Path Data="M2,2 L22,22" Stroke="{Binding $parent[ToggleButton].Foreground}" StrokeThickness="2" IsVisible="{Binding IsVideoHidden}" />
                              </Canvas>
                          </Viewbox>
                      </ToggleButton>
                  </StackPanel>
              </Grid>
          </Border>

          <Border Grid.Row="4"
                  Height="{Binding LaneContainerHeight}"
                  Background="{DynamicResource AccentSubtle}"
                  BorderBrush="{DynamicResource AccentSubtle}"
                  BorderThickness="1"
                  CornerRadius="8">
              <Grid RowDefinitions="18,*">
                  <TextBlock Grid.Row="0"
                             Text="AUDIO"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Foreground="{DynamicResource AccentMuted}"
                             FontSize="10"
                             FontWeight="SemiBold" />
                  <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                      <ToggleButton IsChecked="{Binding IsAudioMuted}"
                                    Focusable="False"
                                    Width="24" Height="22"
                                    CornerRadius="4"
                                    Padding="0">
                          <ToggleButton.Styles>
                              <Style Selector="ToggleButton">
                                  <Setter Property="HorizontalContentAlignment" Value="Center" />
                                  <Setter Property="VerticalContentAlignment" Value="Center" />
                                  <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                  <Setter Property="Background" Value="{DynamicResource BaseBg}" />
                                  <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="ToggleButton:checked">
                                  <Setter Property="Foreground" Value="#FFF" />
                                  <Setter Property="Background" Value="#A04040" />
                              </Style>
                          </ToggleButton.Styles>
                          <TextBlock Text="M" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0" />
                      </ToggleButton>
                  </StackPanel>
              </Grid>
          </Border>
      </Grid>

      <ScrollViewer Grid.Column="2"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled"
                PointerWheelChanged="TimelineScrollViewer_OnPointerWheelChanged">
                        <Grid x:Name="TimelineCanvas"
                              Width="{Binding TimelineCanvasWidth}"
            Height="{Binding TimelineCanvasHeight}"
            RowDefinitions="52,10,Auto,8,Auto"
            HorizontalAlignment="Left">
                        <Border Grid.Row="0"
                                        Height="52"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="TimelineSeekSurface_OnPointerPressed">
                <Grid RowDefinitions="18,*">
                    <ItemsControl ItemsSource="{Binding MinorTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding $parent[UserControl].DataContext.TickWidth}"
                                      Height="18">
                                    <Border Width="1"
                                            Height="14"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            IsVisible="{Binding ShowLine}"
                                            Background="{DynamicResource AccentSubtle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding MajorTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding Width}"
                                      Height="34">
                                    <TextBlock Margin="3,3,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentMuted}"
                                               Text="{Binding Label}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Height="{Binding LaneContainerHeight}"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="TimelineSeekSurface_OnPointerPressed"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TimelineTrack_OnDragOver"
                    DragDrop.Drop="TimelineTrack_OnDrop">
                                <Grid ClipToBounds="True">
                                        <ItemsControl
                                  ItemsSource="{Binding VideoClips}"
                                  Width="{Binding TimelineCanvasWidth}"
                                                                    Height="{Binding LaneContainerHeight}"
                                  HorizontalAlignment="Left"
                                  Classes.hidden="{Binding IsVideoHidden}">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl.hidden">
                                <Setter Property="Opacity" Value="0.3" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="arrangementVm:TimelineClipItem">
                                <Border Canvas.Left="{Binding Left}"
                                        Width="{Binding Width}"
                                        Height="{Binding $parent[UserControl].DataContext.ClipVisualHeight}"
                                    Margin="10,6,0,6"
                                        CornerRadius="6"
                                        Background="#66C2D8C4"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1"
                                        Classes.selected="{Binding IsSelected}">
                                    <Border.Styles>
                                        <Style Selector="Border.selected">
                                            <Setter Property="BorderBrush" Value="White" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </Style>
                                    </Border.Styles>
                                    <TextBlock Margin="8,0"
                                               VerticalAlignment="Center"
                                               Foreground="#222222"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Height="{Binding LaneContainerHeight}"
                    Background="{DynamicResource BaseBg}"
                    BorderBrush="{DynamicResource AccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerPressed="TimelineSeekSurface_OnPointerPressed"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TimelineTrack_OnDragOver"
                    DragDrop.Drop="TimelineTrack_OnDrop">
                                <Grid ClipToBounds="True">
                                        <ItemsControl
                                  ItemsSource="{Binding AudioClips}"
                                  Width="{Binding TimelineCanvasWidth}"
                                                                    Height="{Binding LaneContainerHeight}"
                                  HorizontalAlignment="Left"
                                  Classes.muted="{Binding IsAudioMuted}">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl.muted">
                                <Setter Property="Opacity" Value="0.3" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="arrangementVm:TimelineClipItem">
                                <Border Canvas.Left="{Binding Left}"
                                        Width="{Binding Width}"
                                        Height="{Binding $parent[UserControl].DataContext.ClipVisualHeight}"
                                    Margin="10,6,0,6"
                                        CornerRadius="6"
                                    Background="{DynamicResource AccentSubtle}"
                                        BorderBrush="{DynamicResource AccentSubtle}"
                                        BorderThickness="1">
                                    <Grid ClipToBounds="True">
                                        <Image Source="{Binding WaveformImage}"
                                               Stretch="Fill"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Width="2"
                    Height="{Binding PlayheadHeight}"
                    Grid.RowSpan="5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Accent}"
                    IsHitTestVisible="False"
                    IsVisible="{Binding IsPlayheadVisible}">
                <Border.RenderTransform>
                    <TranslateTransform X="{Binding PlayheadVisualLeft}" />
                </Border.RenderTransform>
            </Border>

            <Border x:Name="SelectionBox"
                    Grid.RowSpan="5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#330078D7"
                    BorderBrush="#0078D7"
                    BorderThickness="1"
                    IsHitTestVisible="False"
                    IsVisible="False" />
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
