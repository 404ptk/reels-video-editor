<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReelsVideoEditor.App.Views.Common.BackButton"
             x:Name="Root">
        <UserControl.Styles>
                <Style Selector="Button.backButton">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>

                <Style Selector="Button.backButton:pointerover">
                        <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
                </Style>
        </UserControl.Styles>

        <Button Classes="backButton"
                        Width="120"
                        Height="36"
            BorderThickness="1"
            FontWeight="SemiBold"
            Command="{Binding Command, ElementName=Root}"
                        CommandParameter="{Binding CommandParameter, ElementName=Root}">
                <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                        <Path Data="M11,3 L5,9 L11,15"
                                  Width="12"
                                  Height="12"
                                  Stretch="Uniform"
                                  StrokeThickness="2"
                                  Stroke="{DynamicResource Accent}"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="Back"
                                           Foreground="{DynamicResource Accent}"
                                           VerticalAlignment="Center" />
                </StackPanel>
        </Button>
</UserControl>