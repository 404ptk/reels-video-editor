<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Export"
             x:Class="ReelsVideoEditor.App.Views.Export.ExportPanelView"
             x:DataType="vm:ExportViewModel"
             Background="{DynamicResource BaseBg}">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#444444" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
        </Style>

        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="ComboBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#444444" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
        </Style>

        <Style Selector="ComboBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
        </Style>
        
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
        </Style>

        <Style Selector="Button.actionBtn">
            <Setter Property="Background" Value="{DynamicResource BaseBgSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSubtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
        </Style>

        <Style Selector="Button.actionBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="Button.primaryBtn">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Padding" Value="24,14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.primaryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        
        <Style Selector="Button.primaryBtn:pressed /template/ ContentPresenter">
            <Setter Property="RenderTransform" Value="scale(0.98)" />
        </Style>

        <Style Selector="TextBlock.header">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="Border.exportStatus">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="#1D2F25" />
            <Setter Property="BorderBrush" Value="#2E8B57" />
        </Style>

        <Style Selector="Border.exportStatus.error">
            <Setter Property="Background" Value="#3A1F1F" />
            <Setter Property="BorderBrush" Value="#A94442" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="600" Spacing="24" HorizontalAlignment="Center" Margin="0,32,0,32">
                
                <TextBlock Text="Export Timeline" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource Accent}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />

                <Border Classes="exportStatus"
                    Classes.error="{Binding IsStatusError}"
                    IsVisible="{Binding HasStatusMessage}">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,6,Auto">
                    <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding StatusTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="White" />

                    <Button Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Classes="actionBtn"
                        Content="Dismiss"
                        Command="{Binding DismissStatusCommand}" />

                    <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="White"
                           Opacity="0.9"
                           TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- Export Path -->
                <Border Background="{DynamicResource BaseBgSoft}" 
                        BorderBrush="{DynamicResource AccentSubtle}" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Export Destination" Classes="header" />
                        <Grid ColumnDefinitions="*,16,Auto">
                            <TextBox Grid.Column="0" 
                                     Text="{Binding OutputPath}" 
                                     IsReadOnly="True" 
                                     Watermark="Select an export directory..." />
                            <Button Grid.Column="2" 
                                    Classes="actionBtn"
                                    Command="{Binding BrowseDirectoryCommand}" 
                                    Content="Browse Folder"
                                    IsEnabled="{Binding !IsExporting}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Output Specs -->
                <Border Background="{DynamicResource BaseBgSoft}" 
                        BorderBrush="{DynamicResource AccentSubtle}" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                        <StackPanel Spacing="0">
                            <TextBlock Text="Filename" Classes="header" />
                            <TextBox Text="{Binding OutputName}" 
                                     Watermark="output"
                                     IsEnabled="{Binding !IsExporting}" />
                        </StackPanel>
                </Border>
                
                <!-- Resolution Specs -->
                <Border Background="{DynamicResource BaseBgSoft}" 
                        BorderBrush="{DynamicResource AccentSubtle}" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <Grid ColumnDefinitions="*,24,*">
                        <StackPanel Grid.Column="0" Spacing="0">
                            <TextBlock Text="Resolution" Classes="header" />
                            <ComboBox ItemsSource="{Binding AvailableResolutions}"
                                      SelectedItem="{Binding SelectedResolution}"
                                      IsEnabled="{Binding !IsExporting}">
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="0">
                            <TextBlock Text="Aspect Ratio" Classes="header" />
                            <ComboBox ItemsSource="{Binding AvailableFormats}"
                                      SelectedItem="{Binding SelectedFormat}"
                                      IsEnabled="{Binding !IsExporting}">
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Progress and Submit -->
                <StackPanel Spacing="16" Margin="0,16,0,0">
                    <ProgressBar Minimum="0" Maximum="100" 
                                 Value="{Binding ExportProgress}"
                                 Height="8"
                                 CornerRadius="4"
                                 IsVisible="{Binding IsExporting}"
                                 Foreground="{DynamicResource Accent}"
                                 Background="{DynamicResource AccentSubtle}" />

                    <Button Classes="primaryBtn"
                            Command="{Binding ExportProjectCommand}"
                            IsEnabled="{Binding !IsExporting}">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                  Fill="#111111"
                                  Width="20" Height="20" Stretch="Uniform" />
                            <TextBlock Text="Export Video" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
