<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Export"
             x:Class="ReelsVideoEditor.App.Views.Export.ExportPanelView"
             x:DataType="vm:ExportViewModel">

    <Grid RowDefinitions="Auto,*">
        <Border Padding="16"
                Background="{StaticResource BaseBg}">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding Title}"
                           Foreground="{DynamicResource Accent}"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}"
                           Foreground="{DynamicResource AccentMuted}"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="Export options will be available here"
                       Foreground="{DynamicResource AccentMuted}"
                       FontSize="13"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>

</UserControl>
