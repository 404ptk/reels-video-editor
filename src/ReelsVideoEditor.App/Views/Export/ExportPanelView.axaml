<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReelsVideoEditor.App.ViewModels.Export"
             x:Class="ReelsVideoEditor.App.Views.Export.ExportPanelView"
             x:DataType="vm:ExportViewModel">

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="Export options will be available here"
                       Foreground="{DynamicResource AccentMuted}"
                       FontSize="13"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>

</UserControl>
